# ─── News Video Generator — Configuration ───────────────────────
# Copie ce fichier en .env et remplis tes clés

# REQUIS pour les vraies news en temps réel (Claude + WebSearch)
# Inscription : https://console.anthropic.com
ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OPTIONNEL — Photos HD libres de droits (50 req/h gratuit)
# Inscription : https://unsplash.com/developers
UNSPLASH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONNEL — Source de news supplémentaire (100 req/jour gratuit)
# Inscription : https://newsapi.org/register
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
